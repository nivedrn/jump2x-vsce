{
  "name": "leap",
  "displayName": "Leap",
  "description": "Quickly open and manage favorite and discovered workspaces.",
  "version": "1.0.0",
  "publisher": "devn",
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:leap.workspaceExplorer",
    "onCommand:leap.quickOpenWorkspace",
    "onCommand:leap.addCurrentWorkspace",
    "onCommand:leap.refreshWorkspaces",
    "onCommand:leap.openWorkspace",
    "onCommand:leap.removeFavorite",
    "onCommand:leap.hideWorkspace",
    "onCommand:leap.restoreWorkspace",
    "onCommand:leap.openSettings"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "leap.workspaceExplorer",
          "name": "Leap"
        }
      ]
    },
    "commands": [
      {
        "command": "leap.addCurrentWorkspace",
        "title": "Leap: Add Current Workspace to Favorites",
        "category": "Leap",
        "icon": "$(star-add)"
      },
      {
        "command": "leap.refreshWorkspaces",
        "title": "Leap: Refresh Workspaces",
        "category": "Leap",
        "icon": "$(refresh)"
      },
      {
        "command": "leap.openWorkspace",
        "title": "Leap: Open Workspace",
        "category": "Leap"
      },
      {
        "command": "leap.removeFavorite",
        "title": "Leap: Remove Favorite",
        "category": "Leap",
        "icon": "$(trash)"
      },
      {
        "command": "leap.hideWorkspace",
        "title": "Leap: Hide Workspace",
        "category": "Leap",
        "icon": "$(eye-closed)"
      },
      {
        "command": "leap.restoreWorkspace",
        "title": "Leap: Restore Workspace",
        "category": "Leap",
        "icon": "$(eye)"
      },
      {
        "command": "leap.openSettings",
        "title": "Leap: Open Settings",
        "category": "Leap",
        "icon": "$(gear)"
      },
      {
        "command": "leap.quickOpenWorkspace",
        "title": "Leap: Quick Open Workspace",
        "category": "Leap"
      }
    ],
    "keybindings": [
      {
        "command": "leap.quickOpenWorkspace",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "leap.addCurrentWorkspace",
          "when": "view == leap.workspaceExplorer",
          "group": "navigation@1"
        },
        {
          "command": "leap.refreshWorkspaces",
          "when": "view == leap.workspaceExplorer",
          "group": "navigation@2"
        },
        {
          "command": "leap.openSettings",
          "when": "view == leap.workspaceExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "leap.removeFavorite",
          "when": "view == leap.workspaceExplorer && viewItem == favoriteWorkspace",
          "group": "inline"
        },
        {
          "command": "leap.addCurrentWorkspace",
          "when": "view == leap.workspaceExplorer && viewItem == discoveredWorkspace",
          "group": "inline"
        },
        {
          "command": "leap.hideWorkspace",
          "when": "view == leap.workspaceExplorer && viewItem == discoveredWorkspace",
          "group": "inline"
        },
        {
          "command": "leap.restoreWorkspace",
          "when": "view == leap.workspaceExplorer && viewItem == hiddenWorkspace",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "leap.openWorkspace",
          "when": "false"
        },
        {
          "command": "leap.removeFavorite",
          "when": "false"
        },
        {
          "command": "leap.hideWorkspace",
          "when": "false"
        },
        {
          "command": "leap.restoreWorkspace",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Leap",
      "properties": {
        "leap.workspacesDirectories": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Directories to scan for git repositories and .code-workspace files. Supports multiple paths."
        },
        "leap.excludedDirectories": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Directories to skip during scanning. Full paths that the scanner should not traverse."
        },
        "leap.recursiveScan": {
          "type": "boolean",
          "default": true,
          "description": "Recursively scan nested folders in workspacesDirectories."
        },
        "leap.maxScanDepth": {
          "type": "number",
          "default": -1,
          "description": "Maximum folder depth to scan from each root directory. Depth is measured in folder levels from the configured root (0 = root only, 1 = include direct children). Use -1 for unlimited depth."
        },
        "leap.includeCodeWorkspaceFiles": {
          "type": "boolean",
          "default": true,
          "description": "Include discovered .code-workspace files."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/workspace-utils.test.js",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "vsce package --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
